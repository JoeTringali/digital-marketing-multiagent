# ── LLM Backend ────────────────────────────────────────────────────────────────
# Choose: openai | azure | ollama
LLM_BACKEND=openai

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4o

# ── Azure OpenAI (only needed when LLM_BACKEND=azure) ─────────────────────────
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ── Ollama (only needed when LLM_BACKEND=ollama) ──────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3  ← override the model name for Ollama

# ── Application behaviour ──────────────────────────────────────────────────────
# Set to "false" to disable automatic report saving
SAVE_REPORT=true

# Conversation mode: interactive | batch
# (overridden by the --batch CLI flag; this sets the default)
CONVERSATION_MODE=interactive
